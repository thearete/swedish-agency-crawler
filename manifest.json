{
  "manifest_version": 3,
  "name": "Swedish Agency Crawler",
  "version": "1.0.0",
  "description": "Find international cooperation contacts at Swedish government agencies",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.government.se/*",
    "https://*.se/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
